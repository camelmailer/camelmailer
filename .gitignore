/target

# Proxy-CA shim some sandboxed CI environments inject into the build
# context for TLS interception; never commit one.
._verify-ca.crt

# Local environment + real configuration (keep the examples).
.env
config/*
!config/camelmailer.example.yml

# The (pre-split-out) repo-wide .gitignore excludes *.sql (MariaDB dumps);
# the embedded sqlx migrations are source code and must be tracked.
!crates/camelmailer-db/migrations/*.sql
__pycache__/
