{
  "name": "two-factor-code",
  "description": "One-time security code (login step-up, sensitive action).",
  "variables": [
    "product",
    "support_email",
    "code",
    "expires_in"
  ],
  "subject": "{{ code }} is your {{ product }} security code",
  "html_body": "<!doctype html>\n<html>\n<head>\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n  <meta name=\"color-scheme\" content=\"light\">\n</head>\n<body style=\"margin:0;padding:0;background:#f4f4f5;font-family:-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;\">\n  <div style=\"display:none;max-height:0;overflow:hidden;\">Your one-time code.</div>\n  <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f4f4f5;\">\n    <tr><td align=\"center\" style=\"padding:32px 16px;\">\n      <table role=\"presentation\" width=\"560\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:560px;width:100%;\">\n        <tr><td style=\"padding:0 8px 16px;font-size:16px;font-weight:700;color:#18181b;\">{{ product }}</td></tr>\n        <tr><td style=\"background:#ffffff;border:1px solid #e4e4e7;border-radius:12px;padding:32px;\">\n<h1 style=\"margin:0 0 16px;font-size:20px;line-height:1.3;color:#18181b;\">Your security code</h1><p style=\"margin:0 0 16px;font-size:15px;line-height:1.6;color:#3f3f46;\">Enter this code to continue. It expires in {{ expires_in }}.</p><div style=\"margin:8px 0 20px;padding:16px;background:#f4f4f5;border-radius:8px;font-family:ui-monospace,Menlo,monospace;font-size:26px;letter-spacing:6px;text-align:center;color:#18181b;font-weight:700;\">{{ code }}</div><p style=\"margin:16px 0 0;font-size:13px;line-height:1.6;color:#a1a1aa;\">You receive this because it concerns the security of your {{ product }} account. Never share this code — {{ product }} will never ask for it.</p>\n        </td></tr>\n        <tr><td style=\"padding:16px 8px;font-size:12px;line-height:1.6;color:#a1a1aa;\">\n          Questions? Just reply to this email or contact\n          <a href=\"mailto:{{ support_email }}\" style=\"color:#71717a;\">{{ support_email }}</a>.\n        </td></tr>\n      </table>\n    </td></tr>\n  </table>\n</body>\n</html>",
  "text_body": "Your {{ product }} security code: {{ code }}\n\nIt expires in {{ expires_in }}. Never share this code — {{ product }} will never ask for it."
}
