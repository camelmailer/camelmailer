{
  "name": "trial-ending",
  "description": "Trial expiry reminder with upgrade CTA.",
  "variables": [
    "product",
    "support_email",
    "name",
    "days_left",
    "action_url"
  ],
  "subject": "Your {{ product }} trial ends in {{ days_left }} days",
  "html_body": "<!doctype html>\n<html>\n<head>\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n  <meta name=\"color-scheme\" content=\"light\">\n</head>\n<body style=\"margin:0;padding:0;background:#f4f4f5;font-family:-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;\">\n  <div style=\"display:none;max-height:0;overflow:hidden;\">Don't lose access to your work.</div>\n  <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f4f4f5;\">\n    <tr><td align=\"center\" style=\"padding:32px 16px;\">\n      <table role=\"presentation\" width=\"560\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:560px;width:100%;\">\n        <tr><td style=\"padding:0 8px 16px;font-size:16px;font-weight:700;color:#18181b;\">{{ product }}</td></tr>\n        <tr><td style=\"background:#ffffff;border:1px solid #e4e4e7;border-radius:12px;padding:32px;\">\n<h1 style=\"margin:0 0 16px;font-size:20px;line-height:1.3;color:#18181b;\">{{ days_left }} days left in your trial</h1><p style=\"margin:0 0 16px;font-size:15px;line-height:1.6;color:#3f3f46;\">Hi {{ name }}, your {{ product }} trial ends in <strong>{{ days_left }} days</strong>. Pick a plan to keep everything running without interruption.</p><table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\" style=\"margin:8px 0 20px;\"><tr><td style=\"background:#18181b;border-radius:8px;\"><a href=\"{{ action_url }}\" style=\"display:inline-block;padding:12px 24px;font-size:15px;font-weight:600;color:#ffffff;text-decoration:none;\">Choose a plan</a></td></tr></table><p style=\"margin:16px 0 0;font-size:13px;line-height:1.6;color:#a1a1aa;\">Or copy this link into your browser:<br><a href=\"{{ action_url }}\" style=\"color:#71717a;word-break:break-all;\">{{ action_url }}</a></p><p style=\"margin:16px 0 0;font-size:13px;line-height:1.6;color:#a1a1aa;\">Questions about plans? Just reply — happy to help.</p>\n        </td></tr>\n        <tr><td style=\"padding:16px 8px;font-size:12px;line-height:1.6;color:#a1a1aa;\">\n          Questions? Just reply to this email or contact\n          <a href=\"mailto:{{ support_email }}\" style=\"color:#71717a;\">{{ support_email }}</a>.\n        </td></tr>\n      </table>\n    </td></tr>\n  </table>\n</body>\n</html>",
  "text_body": "Hi {{ name }},\n\nYour {{ product }} trial ends in {{ days_left }} days.\nChoose a plan to keep everything running: {{ action_url }}"
}
